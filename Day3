List<Integer> nums = new List<Integer>{23, 12, 111, 8, 3, 549};

if (nums.size() >= 2) {                          // EDIT 1: boundary fixed (yours)

    // EDIT 3: honest openers — first two REAL elements, sorted into boxes
    Integer largest = nums[0];
    Integer secondLargest = nums[1];
    if (secondLargest > largest) {               // wrong way round? swap
        Integer temp = largest;                  // Day 1, problem 1 — the swap, employed at last
        largest = secondLargest;
        secondLargest = temp;
    }

    for (Integer n : nums) {
        if (n > largest) {
            secondLargest = largest;             // your transfer — was right since round 3
            largest = n;
        } else if (n < largest && n > secondLargest) {
            secondLargest = n;
        }
    }
